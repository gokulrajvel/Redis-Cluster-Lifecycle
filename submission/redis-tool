#!/usr/bin/env python3
import os
import sys
import shutil
import re
import subprocess

# Define directory structures relative to script location
SUBMISSION_DIR = os.path.dirname(os.path.abspath(__file__))
ANSIBLE_DIR = os.path.join(SUBMISSION_DIR, "ansible")

def check_prerequisites():
    """Verify Docker/Podman and Ansible 2.14+ are installed on the system."""
    import shutil
    import subprocess
    import re

    # 1. Check Docker or Podman
    docker_exists = shutil.which("docker") is not None
    podman_exists = shutil.which("podman") is not None

    runtime_name = None
    runtime_version = "unknown"
    if podman_exists:
        runtime_name = "Podman"
        try:
            res = subprocess.run(["podman", "--version"], capture_output=True, text=True, check=True)
            match = re.search(r'version\s+(\d+\.\d+\.\d+)', res.stdout)
            if match:
                runtime_version = match.group(1)
        except Exception:
            pass
    elif docker_exists:
        runtime_name = "Docker"
        try:
            res = subprocess.run(["docker", "--version"], capture_output=True, text=True, check=True)
            match = re.search(r'version\s+(\d+\.\d+\.\d+)', res.stdout)
            if match:
                runtime_version = match.group(1)
        except Exception:
            pass

    # 2. Check Ansible 2.14+
    ansible_exists = shutil.which("ansible-playbook") is not None
    ansible_version = "unknown"
    ansible_ok = False
    if ansible_exists:
        try:
            res = subprocess.run(["ansible-playbook", "--version"], capture_output=True, text=True, check=True)
            first_line = res.stdout.splitlines()[0]
            match = re.search(r'(?:core\s+)?(\d+\.\d+(?:\.\d+)?)', first_line)
            if match:
                ansible_version = match.group(1)
                version_parts = [int(x) for x in ansible_version.split('.')]
                while len(version_parts) < 3:
                    version_parts.append(0)
                if version_parts >= [2, 14, 0]:
                    ansible_ok = True
        except Exception:
            pass

    if runtime_name and ansible_exists and ansible_ok:
        print(f"✓ {runtime_name} {runtime_version} found")
        print(f"✓ Ansible {ansible_version} found")
        print("Proceeding...")
    else:
        if not runtime_name:
            print("✗ Container runtime not found (Docker or Podman)")
            print("  Install Podman: https://podman.io/docs/installation")
            print("  Install Docker: https://docs.docker.com/engine/install/")
        if not ansible_exists or not ansible_ok:
            if not ansible_exists:
                print("✗ Ansible not found")
            else:
                print(f"✗ Ansible version {ansible_version} is below the required 2.14+")
            print("  Install: pip install ansible (or use your OS package manager)")
        print("Please install the missing dependencies and retry.")
        sys.exit(1)

def run_playbook(cmd, log_filename=None):
    """Executes the ansible-playbook command and streams the output to stdout and log file."""
    print(f"Running command: {' '.join(cmd)}")
    
    log_file_path = None
    if log_filename:
        output_dir = os.path.join(SUBMISSION_DIR, "output")
        os.makedirs(output_dir, exist_ok=True)
        log_file_path = os.path.join(output_dir, log_filename)
        print(f"Logging output to {log_file_path}")

    if log_file_path:
        with open(log_file_path, "w") as f:
            process = subprocess.Popen(
                cmd,
                cwd=ANSIBLE_DIR,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True
            )
            # Stream output live
            for line in process.stdout:
                sys.stdout.write(line)
                sys.stdout.flush()
                f.write(line)
            process.wait()
            return process.returncode
    else:
        result = subprocess.run(cmd, cwd=ANSIBLE_DIR)
        return result.returncode

def main():
    check_prerequisites()

    import argparse
    parser = argparse.ArgumentParser(description="Redis Cluster Management CLI Tool")
    subparsers = parser.add_subparsers(dest="command", required=True)

    # 1. provision
    prov_parser = subparsers.add_parser("provision", help="Provision Redis nodes and form the cluster")
    prov_parser.add_argument("--version", default="7.0.15", help="Redis version to deploy")
    prov_parser.add_argument("--masters", type=int, default=3, help="Number of master nodes")
    prov_parser.add_argument("--replicas-per-master", type=int, default=1, help="Replicas per master")

    # 2. status
    subparsers.add_parser("status", help="Check status of the Redis Cluster nodes")

    # 3. upgrade
    up_parser = subparsers.add_parser("upgrade", help="Perform a rolling upgrade of the Redis Cluster")
    up_parser.add_argument("--target-version", default="7.2.6", help="Target Redis version to upgrade to")
    up_parser.add_argument("--strategy", default="rolling", choices=["rolling"], help="Upgrade strategy")
    up_parser.add_argument("--keys", type=int, help="Number of keys to verify during baseline and final checks (defaults to metadata:num_keys or 1000)")

    # 4. data (nested commands)
    data_parser = subparsers.add_parser("data", help="Redis data operations")
    data_subparsers = data_parser.add_subparsers(dest="data_command", required=True)
    
    seed_parser = data_subparsers.add_parser("seed", help="Seed test data into the cluster")
    seed_parser.add_argument("--keys", type=int, default=1000, help="Number of keys to seed")
    
    data_verify_parser = data_subparsers.add_parser("verify", help="Verify that data routes and retrieves correctly")
    data_verify_parser.add_argument("--keys", type=int, help="Number of keys to verify (defaults to metadata:num_keys or 1000)")
 
    # 5. verify
    verify_parser = subparsers.add_parser("verify", help="Verify the cluster health and topology")
    verify_parser.add_argument("--full", action="store_true", help="Perform a full verification check")
    verify_parser.add_argument("--keys", type=int, help="Number of keys to verify (defaults to metadata:num_keys or 1000)")

    args = parser.parse_args()

    # Determine command execution list and log files
    cmd = []
    log_filename = None

    if args.command == "provision":
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/provision.yml",
            "-e", f"redis_version={args.version}",
            "-e", f"cluster_replicas={args.replicas_per_master}"
        ]
        log_filename = "provision_output.txt"

    elif args.command == "status":
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/status.yml"
        ]
        log_filename = "status_output.txt"

    elif args.command == "upgrade":
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/upgrade.yml",
            "-e", f"redis_version={args.target_version}"
        ]
        if args.keys is not None:
            cmd.extend(["-e", f"num_keys={args.keys}"])
        log_filename = "upgrade_output.txt"

    elif args.command == "data" and args.data_command == "seed":
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/seed.yml",
            "-e", f"num_keys={args.keys}"
        ]
        log_filename = "data_seed_output.txt"

    elif args.command == "data" and args.data_command == "verify":
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/data_verify.yml"
        ]
        if args.keys is not None:
            cmd.extend(["-e", f"num_keys={args.keys}"])
        log_filename = "data_verify_output.txt"

    elif args.command == "verify":
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/verify.yml"
        ]
        if args.full:
            cmd.extend(["-e", "full_check=true"])
        if args.keys is not None:
            cmd.extend(["-e", f"num_keys={args.keys}"])
        log_filename = "verify_output.txt"

    # Execute
    return_code = run_playbook(cmd, log_filename)
    if return_code == 0 and args.command == "provision":
        print("\n--- Final Cluster Topology ---")
        status_cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/status.yml"
        ]
        run_playbook(status_cmd)
    sys.exit(return_code)

if __name__ == "__main__":
    main()


