#!/usr/bin/env python3
import os
import sys
import shutil
import re
import subprocess
import json
import stat
import time
from datetime import datetime

# Define directory structures relative to script location
SUBMISSION_DIR = os.path.dirname(os.path.abspath(__file__))
ANSIBLE_DIR = os.path.join(SUBMISSION_DIR, "ansible")

# Set ANSIBLE_CONFIG explicitly in process environment to bypass world-writable directory checks
os.environ["ANSIBLE_CONFIG"] = os.path.join(ANSIBLE_DIR, "ansible.cfg")

# Dynamic DOCKER_CONTEXT detection:
# If DOCKER_CONTEXT is not set, check if default context has redis-node-1 running.
if "DOCKER_CONTEXT" not in os.environ:
    try:
        res = subprocess.run(["docker", "--context", "default", "inspect", "redis-node-1"], capture_output=True, text=True)
        if res.returncode == 0:
            os.environ["DOCKER_CONTEXT"] = "default"
    except Exception:
        pass

# --- S5: Structured Logging Setup ---
LOGS_DIR = os.path.join(SUBMISSION_DIR, "logs")
os.makedirs(LOGS_DIR, exist_ok=True)
# --- End S5 Setup ---

def fix_ansible_permissions():
    """Fix world-writable directory issue for ansible.cfg."""
    current = os.stat(ANSIBLE_DIR).st_mode
    # Remove world-write permission
    fixed = current & ~stat.S_IWOTH
    if current != fixed:
        os.chmod(ANSIBLE_DIR, fixed)
        print("Fixed ansible directory permissions.")

def check_prerequisites():
    """Verify Docker/Podman and Ansible 2.14+ are installed on the system."""
    fix_ansible_permissions()
    import shutil
    import subprocess
    import re

    # 1. Check Docker or Podman
    docker_exists = shutil.which("docker") is not None
    podman_exists = shutil.which("podman") is not None

    runtime_env = os.environ.get("CONTAINER_RUNTIME", "").lower()
    runtime_name = None
    runtime_version = "unknown"

    # Detect if redis-node-1 is already running in one of the runtimes
    is_docker_running = False
    if docker_exists:
        try:
            res = subprocess.run(["docker", "inspect", "redis-node-1"], capture_output=True, text=True)
            if res.returncode == 0:
                is_docker_running = True
        except Exception:
            pass

    is_podman_running = False
    if podman_exists:
        try:
            res = subprocess.run(["podman", "inspect", "redis-node-1"], capture_output=True, text=True)
            if res.returncode == 0:
                is_podman_running = True
        except Exception:
            pass

    if is_docker_running:
        runtime_name = "Docker"
    elif is_podman_running:
        runtime_name = "Podman"
    elif runtime_env == "docker" and docker_exists:
        runtime_name = "Docker"
    elif runtime_env == "podman" and podman_exists:
        runtime_name = "Podman"
    elif docker_exists:  # Match up.sh default order of preference
        runtime_name = "Docker"
    elif podman_exists:
        runtime_name = "Podman"

    if runtime_name == "Docker":
        try:
            res = subprocess.run(["docker", "--version"], capture_output=True, text=True, check=True)
            match = re.search(r'version\s+(\d+\.\d+\.\d+)', res.stdout)
            if match:
                runtime_version = match.group(1)
        except Exception:
            pass
    elif runtime_name == "Podman":
        try:
            res = subprocess.run(["podman", "--version"], capture_output=True, text=True, check=True)
            match = re.search(r'version\s+(\d+\.\d+\.\d+)', res.stdout)
            if match:
                runtime_version = match.group(1)
        except Exception:
            pass

    # 2. Check Ansible 2.14+
    ansible_exists = shutil.which("ansible-playbook") is not None
    ansible_version = "unknown"
    ansible_ok = False
    if ansible_exists:
        try:
            res = subprocess.run(["ansible-playbook", "--version"], capture_output=True, text=True, check=True)
            first_line = res.stdout.splitlines()[0]
            match = re.search(r'(?:core\s+)?(\d+\.\d+(?:\.\d+)?)', first_line)
            if match:
                ansible_version = match.group(1)
                version_parts = [int(x) for x in ansible_version.split('.')]
                while len(version_parts) < 3:
                    version_parts.append(0)
                if version_parts >= [2, 14, 0]:
                    ansible_ok = True
        except Exception:
            pass

    if runtime_name and ansible_exists and ansible_ok:
        print(f"✓ {runtime_name} {runtime_version} found")
        print(f"✓ Ansible {ansible_version} found")
        print("Proceeding...")
    else:
        if not runtime_name:
            print("✗ Container runtime not found (Docker or Podman)")
            print("  Install Podman: https://podman.io/docs/installation")
            print("  Install Docker: https://docs.docker.com/engine/install/")
        if not ansible_exists or not ansible_ok:
            if not ansible_exists:
                print("✗ Ansible not found")
            else:
                print(f"✗ Ansible version {ansible_version} is below the required 2.14+")
            print("  Install: pip install ansible (or use your OS package manager)")
        print("Please install the missing dependencies and retry.")
        sys.exit(1)

def run_playbook(cmd, log_filename=None):
    """Executes the ansible-playbook command and streams the output to stdout and log file."""
    print(f"Running command: {' '.join(cmd)}")
    
    log_file_path = None
    if log_filename:
        output_dir = os.path.join(SUBMISSION_DIR, "output")
        os.makedirs(output_dir, exist_ok=True)
        log_file_path = os.path.join(output_dir, log_filename)
        print(f"Logging output to {log_file_path}")

    if log_file_path:
        with open(log_file_path, "w") as f:
            process = subprocess.Popen(
                cmd,
                cwd=ANSIBLE_DIR,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True
            )
            # Stream output live
            for line in process.stdout:
                sys.stdout.write(line)
                sys.stdout.flush()
                f.write(line)
            process.wait()
            return process.returncode
    else:
        result = subprocess.run(cmd, cwd=ANSIBLE_DIR)
        return result.returncode

# --- S5: Structured Logging Functions ---
def write_structured_log(command_name, args_dict, ansible_cmd, return_code, duration, log_filename, error_msg=None):
    """Write a JSON log file and append a summary line to operations.log."""
    now = datetime.now()
    timestamp_str = now.strftime("%Y-%m-%dT%H:%M:%S")
    file_timestamp = now.strftime("%Y%m%d_%H%M%S")

    status = "success" if return_code == 0 else "failed"

    # Build the JSON log entry
    log_entry = {
        "timestamp": timestamp_str,
        "command": command_name,
        "args": args_dict,
        "ansible_command": " ".join(ansible_cmd) if ansible_cmd else "",
        "status": status,
        "return_code": return_code,
        "duration_seconds": round(duration, 1),
        "output_file": f"output/{log_filename}" if log_filename else ""
    }
    if error_msg:
        log_entry["error"] = error_msg

    # Write per-operation JSON log file
    json_log_path = os.path.join(LOGS_DIR, f"{command_name}_{file_timestamp}.json")
    with open(json_log_path, "w") as f:
        json.dump(log_entry, f, indent=2)

    # Append one-line summary to operations.log
    ops_log_path = os.path.join(LOGS_DIR, "operations.log")
    summary = f"{timestamp_str} | {command_name} | {status} | {round(duration, 1)}s"
    if error_msg:
        summary += f" | {error_msg}"
    elif status == "success":
        # Add a brief description based on the command
        if command_name == "upgrade" and "target_version" in args_dict:
            summary += f" | all nodes on v{args_dict['target_version']}"
        elif command_name == "provision" and "version" in args_dict:
            summary += f" | cluster v{args_dict['version']}"
        elif command_name == "rollback" and "target_version" in args_dict:
            summary += f" | rolled back to v{args_dict['target_version']}"
        elif command_name == "scale_out":
            summary += " | added 2 new nodes"
        elif command_name == "scale_in" and "remove_node" in args_dict:
            summary += f" | removed node {args_dict['remove_node']}"
    with open(ops_log_path, "a") as f:
        f.write(summary + "\n")

    return json_log_path
# --- End S5 Structured Logging Functions ---

def get_current_nodes():
    hosts_ini_path = os.path.join(SUBMISSION_DIR, "ansible", "inventory", "hosts.ini")
    current_nodes = []
    if os.path.exists(hosts_ini_path):
        with open(hosts_ini_path, "r") as f:
            lines = f.readlines()
        in_redis_nodes = False
        for line in lines:
            line = line.strip()
            if not line:
                continue
            if line.startswith("["):
                if line == "[redis_nodes]":
                    in_redis_nodes = True
                else:
                    in_redis_nodes = False
                continue
            if in_redis_nodes:
                node_name = line.split()[0]
                current_nodes.append(node_name)
    if not current_nodes:
        current_nodes = [f"redis-node-{i}" for i in range(1, 7)]
    return current_nodes

def update_compose_yml(new_nodes):
    compose_path = os.path.join(SUBMISSION_DIR, "infra", "compose.yml")
    with open(compose_path, "r") as f:
        content = f.read()

    updated = False
    for node in new_nodes:
        if node not in content:
            k = int(node.split("-")[-1])
            service_snippet = f"""  redis-node-{k}:
    image: redis-node-base:latest
    container_name: redis-node-{k}
    hostname: redis-node-{k}
    networks:
      redis-net:
        ipv4_address: 10.10.0.{10 + k}
    ports:
      - "{2300 + k}:22"
      - "{6470 + k}:6379"

"""
            # Insert right before root-level networks: block
            networks_idx = content.rfind("\nnetworks:")
            if networks_idx == -1:
                networks_idx = content.rfind("networks:")
            if networks_idx != -1:
                content = content[:networks_idx] + "\n" + service_snippet + content[networks_idx:]
                updated = True

    if updated:
        with open(compose_path, "w") as f:
            f.write(content)
        print("Updated compose.yml with new services.")

def update_hosts_ini(current_nodes, new_nodes):
    hosts_ini_path = os.path.join(SUBMISSION_DIR, "ansible", "inventory", "hosts.ini")
    
    redis_nodes_lines = ["[redis_nodes]"]
    for node in current_nodes:
        k = int(node.split("-")[-1])
        redis_nodes_lines.append(f"{node} ansible_host=127.0.0.1 ansible_port={2300 + k}")
        
    new_nodes_lines = ["[new_nodes]"]
    for node in new_nodes:
        k = int(node.split("-")[-1])
        new_nodes_lines.append(f"{node} ansible_host=127.0.0.1 ansible_port={2300 + k}")
        
    content = "\n".join(redis_nodes_lines) + "\n\n" + "\n".join(new_nodes_lines) + "\n\n"
    content += "[cluster_master]\nredis-node-1 ansible_host=127.0.0.1 ansible_port=2301\n\n"
    content += """[all:vars]
ansible_user=root
ansible_ssh_private_key_file=../infra/id_rsa
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'
"""
    with open(hosts_ini_path, "w") as f:
        f.write(content)
    print("Updated hosts.ini with temporary scale groups.")

def finalize_hosts_ini(current_nodes, new_nodes):
    hosts_ini_path = os.path.join(SUBMISSION_DIR, "ansible", "inventory", "hosts.ini")
    all_nodes = current_nodes + new_nodes
    
    redis_nodes_lines = ["[redis_nodes]"]
    for node in all_nodes:
        k = int(node.split("-")[-1])
        redis_nodes_lines.append(f"{node} ansible_host=127.0.0.1 ansible_port={2300 + k}")
        
    new_nodes_lines = ["[new_nodes]"]
        
    content = "\n".join(redis_nodes_lines) + "\n\n" + "\n".join(new_nodes_lines) + "\n\n"
    content += "[cluster_master]\nredis-node-1 ansible_host=127.0.0.1 ansible_port=2301\n\n"
    content += """[all:vars]
ansible_user=root
ansible_ssh_private_key_file=../infra/id_rsa
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'
"""
    with open(hosts_ini_path, "w") as f:
        f.write(content)
    print("Finalized hosts.ini (moved new nodes to active list).")

def main():
    check_prerequisites()
    current_nodes = []
    new_nodes = []

    import argparse
    parser = argparse.ArgumentParser(description="Redis Cluster Management CLI Tool")
    subparsers = parser.add_subparsers(dest="command", required=True)

    # 1. provision
    prov_parser = subparsers.add_parser("provision", help="Provision Redis nodes and form the cluster")
    prov_parser.add_argument("--version", default="7.0.15", help="Redis version to deploy")
    prov_parser.add_argument("--masters", type=int, default=3, help="Number of master nodes")
    prov_parser.add_argument("--replicas-per-master", type=int, default=1, help="Replicas per master")

    # 2. status
    subparsers.add_parser("status", help="Check status of the Redis Cluster nodes")

    # 3. upgrade
    up_parser = subparsers.add_parser("upgrade", help="Perform a rolling upgrade of the Redis Cluster")
    up_parser.add_argument("--target-version", default="7.2.6", help="Target Redis version to upgrade to")
    up_parser.add_argument("--strategy", default="rolling", choices=["rolling"], help="Upgrade strategy")
    up_parser.add_argument("--keys", type=int, help="Number of keys to verify during baseline and final checks (defaults to metadata:num_keys or 1000)")

    # 4. data (nested commands)
    data_parser = subparsers.add_parser("data", help="Redis data operations")
    data_subparsers = data_parser.add_subparsers(dest="data_command", required=True)
    
    seed_parser = data_subparsers.add_parser("seed", help="Seed test data into the cluster")
    seed_parser.add_argument("--keys", type=int, default=1000, help="Number of keys to seed")
    
    data_verify_parser = data_subparsers.add_parser("verify", help="Verify that data routes and retrieves correctly")
    data_verify_parser.add_argument("--keys", type=int, help="Number of keys to verify (defaults to metadata:num_keys or 1000)")
 
    # 5. verify
    verify_parser = subparsers.add_parser("verify", help="Verify the cluster health and topology")
    verify_parser.add_argument("--full", action="store_true", help="Perform a full verification check")
    verify_parser.add_argument("--keys", type=int, help="Number of keys to verify (defaults to metadata:num_keys or 1000)")

    # 6. scale
    scale_parser = subparsers.add_parser("scale", help="Scale the Redis Cluster")
    scale_group = scale_parser.add_mutually_exclusive_group(required=True)
    scale_group.add_argument("--add-nodes", type=int, help="Number of nodes to add (must be an even number)")
    scale_group.add_argument("--remove-node", help="Node ID of the master node to remove")

    # 7. rollback
    rollback_parser = subparsers.add_parser("rollback", help="Roll back the Redis Cluster nodes to a target version")
    rollback_parser.add_argument("--target-version", default="7.0.15", required=True, help="Target Redis version to roll back to")
    rollback_parser.add_argument("--keys", type=int, help="Number of keys to verify during baseline and final checks (defaults to metadata:num_keys or 1000)")

    args = parser.parse_args()

    if args.command == "scale" and args.add_nodes is not None:
        if args.add_nodes < 2 or args.add_nodes % 2 != 0:
            print("Error: --add-nodes must be a positive even integer.")
            sys.exit(1)

    # --- S5: Capture start time and build args dict for logging ---
    start_time = time.time()
    command_name = args.command
    args_dict = {}
    # --- End S5 capture ---

    # Determine command execution list and log files
    cmd = []
    log_filename = None

    if args.command == "provision":
        args_dict = {"version": args.version, "masters": args.masters, "replicas_per_master": args.replicas_per_master}
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/provision.yml",
            "-e", f"redis_version={args.version}",
            "-e", f"cluster_replicas={args.replicas_per_master}"
        ]
        log_filename = "provision_output.txt"

    elif args.command == "status":
        args_dict = {}
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/status.yml"
        ]
        log_filename = "status_output.txt"

    elif args.command == "upgrade":
        args_dict = {"target_version": args.target_version, "strategy": args.strategy}
        if args.keys is not None:
            args_dict["keys"] = args.keys
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/upgrade.yml",
            "-e", f"redis_version={args.target_version}"
        ]
        if args.keys is not None:
            cmd.extend(["-e", f"num_keys={args.keys}"])
        log_filename = "upgrade_output.txt"

    elif args.command == "data" and args.data_command == "seed":
        command_name = "data_seed"
        args_dict = {"keys": args.keys}
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/seed.yml",
            "-e", f"num_keys={args.keys}"
        ]
        log_filename = "data_seed_output.txt"

    elif args.command == "data" and args.data_command == "verify":
        command_name = "data_verify"
        args_dict = {}
        if args.keys is not None:
            args_dict["keys"] = args.keys
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/data_verify.yml"
        ]
        if args.keys is not None:
            cmd.extend(["-e", f"num_keys={args.keys}"])
        log_filename = "data_verify_output.txt"

    elif args.command == "verify":
        args_dict = {"full": args.full}
        if args.keys is not None:
            args_dict["keys"] = args.keys
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/verify.yml"
        ]
        if args.full:
            cmd.extend(["-e", "full_check=true"])
        if args.keys is not None:
            cmd.extend(["-e", f"num_keys={args.keys}"])
        log_filename = "verify_output.txt"

    elif args.command == "scale":
        if args.add_nodes:
            command_name = "scale_out"
            args_dict = {"add_nodes": args.add_nodes}

            # Step 0: Get current nodes and calculate new nodes
            current_nodes = get_current_nodes()
            M = len(current_nodes)
            new_nodes = [f"redis-node-{i}" for i in range(M + 1, M + 1 + args.add_nodes)]

            # Step 0.5: Update compose.yml and hosts.ini
            update_compose_yml(new_nodes)
            update_hosts_ini(current_nodes, new_nodes)

            # Step 1: Start new node containers via podman-compose / docker compose
            infra_dir = os.path.join(SUBMISSION_DIR, "infra")
            print(f"Starting new node containers ({', '.join(new_nodes)})...")

            # Try to detect which container runtime is hosting the existing nodes
            is_docker_running = False
            if shutil.which("docker"):
                try:
                    res = subprocess.run(["docker", "inspect", "redis-node-1"], capture_output=True, text=True)
                    if res.returncode == 0:
                        is_docker_running = True
                except Exception:
                    pass

            compose_cmd = None
            if is_docker_running:
                compose_cmd = ["docker", "compose", "up", "-d"] + new_nodes
            else:
                if shutil.which("podman-compose"):
                    compose_cmd = ["podman-compose", "up", "-d"] + new_nodes
                elif shutil.which("podman"):
                    compose_cmd = ["podman", "compose", "up", "-d"] + new_nodes
                elif shutil.which("docker"):
                    compose_cmd = ["docker", "compose", "up", "-d"] + new_nodes

            if compose_cmd:
                compose_result = subprocess.run(compose_cmd, cwd=infra_dir, capture_output=True, text=True)
                if compose_result.returncode != 0:
                    print(f"Warning: Container start returned non-zero: {compose_result.stderr}")
                else:
                    print("✓ New node containers started")
            else:
                print("✗ No compose tool found (podman-compose/docker compose)")
                # --- S5: Log the failure ---
                duration = time.time() - start_time
                write_structured_log(command_name, args_dict, [], 1, duration, None, "No compose tool found")
                sys.exit(1)

            # Step 2: Wait for SSH to be ready on new nodes
            import socket
            print("Waiting for SSH on new nodes...")
            for node in new_nodes:
                k = int(node.split("-")[-1])
                port = 2300 + k
                for attempt in range(30):
                    try:
                        s = socket.create_connection(("127.0.0.1", port), timeout=2)
                        s.close()
                        print(f"  ✓ Port {port} ready")
                        break
                    except (ConnectionRefusedError, OSError):
                        time.sleep(1)
                else:
                    print(f"  ✗ Timed out waiting for port {port}")
                    # --- S5: Log the failure ---
                    duration = time.time() - start_time
                    write_structured_log(command_name, args_dict, [], 1, duration, None, f"SSH timeout on port {port}")
                    sys.exit(1)

            # Step 3: Detect current Redis version from existing cluster
            target_version = "7.0.15"
            for detect_port in [6471, 6472, 6473, 6474, 6475, 6476]:
                try:
                    res = subprocess.run(
                        ["redis-cli", "-h", "127.0.0.1", "-p", str(detect_port), "info", "server"],
                        capture_output=True, text=True, timeout=5
                    )
                    match = re.search(r'redis_version:(\d+\.\d+\.\d+)', res.stdout)
                    if match:
                        target_version = match.group(1)
                        break
                except Exception:
                    continue
            print(f"Detected cluster version: {target_version}")

            cmd = [
                "ansible-playbook",
                "-i", "inventory/hosts.ini",
                "playbooks/scale_out.yml",
                "-e", f"target_version={target_version}"
            ]
            log_filename = "scale_out_output.txt"
        elif args.remove_node:
            command_name = "scale_in"
            args_dict = {"remove_node": args.remove_node}
            cmd = [
                "ansible-playbook",
                "-i", "inventory/hosts.ini",
                "playbooks/scale_in.yml",
                "-e", f"remove_node_id={args.remove_node}"
            ]
            log_filename = "scale_in_output.txt"

    elif args.command == "rollback":
        args_dict = {"target_version": args.target_version}
        if args.keys is not None:
            args_dict["keys"] = args.keys
        cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/rollback.yml",
            "-e", f"target_version={args.target_version}"
        ]
        if args.keys is not None:
            cmd.extend(["-e", f"num_keys={args.keys}"])
        log_filename = "rollback_output.txt"

    # Execute
    return_code = run_playbook(cmd, log_filename)

    # Finalize inventory if scale_out succeeded
    if return_code == 0 and args.command == "scale" and args.add_nodes:
        finalize_hosts_ini(current_nodes, new_nodes)

    # --- S5: Write structured log after execution ---
    duration = time.time() - start_time
    error_msg = None
    if return_code != 0:
        error_msg = f"ansible-playbook exited with code {return_code}"
    json_log = write_structured_log(command_name, args_dict, cmd, return_code, duration, log_filename, error_msg)
    print(f"Log written to {json_log}")
    # --- End S5 ---

    if return_code == 0 and args.command in ("provision", "scale"):
        print("\n--- Final Cluster Topology ---")
        status_cmd = [
            "ansible-playbook",
            "-i", "inventory/hosts.ini",
            "playbooks/status.yml"
        ]
        run_playbook(status_cmd)
    sys.exit(return_code)

if __name__ == "__main__":
    main()
